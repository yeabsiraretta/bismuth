{
  "name": "bismuth",
  "version": "0.7.1",
  "description": "A local-first PKM editor with Zettelkasten, knowledge management, and intelligent workflows",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "vite dev",
    "dev:web": "node ./scripts/run-vite-web.mjs dev",
    "dev:nas": "vite dev --host 0.0.0.0 --port 4173 --strictPort",
    "build": "vite build",
    "build:web": "node ./scripts/run-vite-web.mjs build",
    "build:nas": "bash ./scripts/build-nas.sh",
    "preview": "vite preview",
    "preview:nas": "vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "serve:nas": "bash ./scripts/serve-nas.sh",
    "nas:healthcheck": "bash ./scripts/nas-healthcheck.sh",
    "nas:bootstrap": "bash ./scripts/nas-bootstrap.sh",
    "nas:install-service": "bash ./scripts/nas-service-install.sh",
    "nas:uninstall-service": "bash ./scripts/nas-service-uninstall.sh",
    "nas:status": "bash ./scripts/nas-service-status.sh",
    "nas:logs": "bash ./scripts/nas-service-logs.sh",
    "nas:restart": "bash ./scripts/nas-service-restart.sh",
    "tauri": "node ./scripts/tauri-cli.mjs",
    "tauri:dev": "node ./scripts/tauri-dev.mjs",
    "tauri:build": "tauri build",
    "tauri:build:linux": "tauri build --target x86_64-unknown-linux-gnu --bundles appimage,deb,rpm",
    "start": "pnpm tauri:dev",
    "mcp:config:render": "node ./scripts/render-mcp-config.mjs",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:coverage": "node ./scripts/run-vitest-coverage.mjs",
    "test:ci": "node ./scripts/run-vitest-coverage.mjs",
    "test:rust": "cd src-tauri && cargo test",
    "e2e": "playwright test -c playwright.regression.config.ts",
    "e2e:smoke": "playwright test -c playwright.smoke.config.ts",
    "e2e:regression": "playwright test -c playwright.regression.config.ts",
    "e2e:ui": "playwright test --ui",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "check": "pnpm lint && pnpm format:check && pnpm test:ci",
    "clean": "rm -rf .svelte-kit build node_modules/.vite src-tauri/target"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/lang-rust": "^6.0.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.5.10",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.43.4",
    "@lucide/svelte": "^1.23.0",
    "@openfeature/web-sdk": "^1.9.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@tauri-apps/plugin-log": "^2.9.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@threlte/core": "^8.0.0",
    "@threlte/extras": "^9.0.0",
    "marked": "^18.0.5",
    "mermaid": "^11.16.0",
    "minisearch": "^7.1.2",
    "svelte-meta-tags": "^4.0.0",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.21.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/cli": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@types/node": "^26.0.1",
    "@types/three": "^0.172.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.17.0",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "eslint-plugin-svelte": "^3.0.0",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^4.0.0",
    "svelte": "^5.15.0",
    "svelte-eslint-parser": "^0.43.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.3.0",
    "vitest": "^4.1.10"
  }
}