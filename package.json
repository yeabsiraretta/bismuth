{
  "name": "bismuth",
  "version": "0.5.0",
  "description": "A local-first PKM editor with Johnny.Decimal, Zettelkasten, and intelligent knowledge management",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "start": "pnpm run tauri:dev",
    "start:web": "pnpm run dev",
    "build:all": "pnpm run build && pnpm run tauri:build",
    "build:web": "pnpm run build",
    "build:desktop": "pnpm run tauri:build",
    "clean": "rm -rf dist node_modules/.vite src-tauri/target",
    "clean:all": "rm -rf dist node_modules src-tauri/target && pnpm install",
    "setup": "pnpm install && pnpm run prepare",
    "version:commit": "node scripts/build/version-bump.js commit",
    "version:push": "node scripts/build/version-bump.js push",
    "version:release": "node scripts/build/version-bump.js release",
    "check": "pnpm run format:check && pnpm run lint && pnpm run lint:css && pnpm run type-check && pnpm run test:ci && pnpm run check:file-sizes && pnpm run validate:workflows",
    "check:file-sizes": "bash scripts/quality/check-file-sizes.sh",
    "check:bundle": "bash scripts/quality/check-bundle-size.sh",
    "check:constitution": "vitest run tests/architecture/__tests__/constitution.test.ts",
    "validate:workflows": "bash scripts/quality/validate-workflows.sh",
    "verify:codebase": "bash scripts/quality/verify-codebase.sh",
    "docs:list": "tsx scripts/build/docs-list.ts",
    "docs:ts": "typedoc --options typedoc.json",
    "fix": "pnpm run format && pnpm run lint:fix",
    "verify": "pnpm run check && pnpm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run --coverage",
    "test:arch": "vitest run tests/architecture/",
    "test:rust": "cd src-tauri && cargo test",
    "deny": "cd src-tauri && cargo deny check",
    "deny:fix": "cd src-tauri && cargo deny check 2>&1 | head -50",
    "test:all": "vitest run && vitest run tests/architecture/",
    "test:full": "bash scripts/quality/run-all-tests.sh --full",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "lint:fast": "oxlint src/",
    "lint:css": "stylelint 'src/**/*.{css,svelte}'",
    "lint:unused": "knip --reporter compact",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "svelte-check --tsconfig ./tsconfig.json",
    "prepare": "husky install",
    "commit": "git-cz",
    "version": "echo $npm_package_version",
    "version:check": "node -p \"require('./package.json').version\"",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:alpha": "standard-version --prerelease alpha",
    "release:beta": "standard-version --prerelease beta",
    "release:rc": "standard-version --prerelease rc",
    "release:dry": "standard-version --dry-run",
    "release:first": "standard-version --first-release"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-markdown": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "chart.js": "^4.4.0",
    "colord": "^2.9.3",
    "date-fns": "^4.3.0",
    "dompurify": "^3.4.10",
    "fast-json-patch": "^3.1.1",
    "focus-trap": "^8.2.1",
    "konva": "^9.0.0",
    "marked": "^18.0.4",
    "rehype-stringify": "^10.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "tone": "^15.0.4",
    "unified": "^11.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^18.4.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.40.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.7",
    "@tsconfig/svelte": "^5.0.0",
    "@types/mdast": "^4.0.4",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "autoprefixer": "^10.5.0",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "eslint-plugin-svelte": "^2.35.0",
    "husky": "^8.0.3",
    "jsdom": "^29.1.1",
    "knip": "^6.0.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.5.15",
    "prettier": "^3.1.0",
    "prettier-plugin-svelte": "^3.1.0",
    "standard-version": "^9.5.0",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^37.0.0",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.6.0",
    "typedoc": "^0.27.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{css,svelte}": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yeabsiraretta/bismuth.git"
  },
  "bugs": {
    "url": "https://github.com/yeabsiraretta/bismuth/issues"
  },
  "homepage": "https://github.com/yeabsiraretta/bismuth#readme",
  "keywords": [
    "pkm",
    "knowledge-management",
    "zettelkasten",
    "johnny-decimal",
    "tauri",
    "svelte",
    "rust",
    "local-first",
    "markdown",
    "notes"
  ],
  "author": "Yeabsira Moges <yeabsiraretta@proton.me>",
  "license": "MIT"
}
