{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2-schema/main/schema.json",
  "productName": "Bismuth",
  "identifier": "com.bismuth.app",
  "version": "0.7.1",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "node ./scripts/run-vite-dev.mjs dev",
    "beforeBuildCommand": "pnpm build",
    "removeUnusedCommands": true
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Bismuth",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "maximizable": true,
        "dragDropEnabled": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; font-src 'self' data:; connect-src ipc: http://ipc.localhost https: http: ws://localhost:5173 ws://127.0.0.1:5173 ws://[::1]:5173"
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": [
          "bismuth"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "A local-first personal knowledge management editor",
    "longDescription": "Bismuth is a local-first PKM editor for managing notes, writing, and knowledge. It features a Markdown editor, calendar, canvas, graph view, and more — all stored locally in your vault.",
    "copyright": "Copyright (c) 2024 yeabsiramoges",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "mimeType": "text/markdown",
        "description": "Markdown Document"
      },
      {
        "ext": [
          "canvas"
        ],
        "mimeType": "application/json",
        "description": "Bismuth Canvas"
      }
    ]
  }
}